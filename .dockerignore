# Build artefacts
**/bin/
**/obj/

# SQLite database files — created fresh inside the container
# Note: DevMetrics.Infrastructure/Data/ contains AppDbContext.cs source — do NOT exclude it.
# Only exclude the Api's runtime database directory.
**/*.db
**/*.db-shm
**/*.db-wal
DevMetrics.Api/Data/

# Logs
**/Logs/

# Test project — not needed in the image
DevMetrics.Tests/
TestResults/

# Git metadata
.git/
.github/

# IDE / OS
.vs/
.vscode/
*.user
.DS_Store
Thumbs.db

# Secrets and environment overrides
.env
secrets.json
**/secrets.json

# Environment-specific appsettings — keep only base + Production
**/appsettings.Development.json
**/appsettings.Testing.json

# NuGet
*.nupkg
