{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=./Data/devmetrics.db"
  },

  "Email": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "DevMetrics",
    "UseSsl": false,
    "Enabled": false,
    "Recipients": [],
    "WeeklySummaryTemplatePath": "",
    "DashboardBaseUrl": "http://localhost:5000"
  },

  "CronExpressions": {
    "HourlyScan":   "0 * * * *",
    "WeeklyReport": "0 9 * * 1"
  },

  "EmailTemplates": {
    "WeeklySummaryPath": "Templates/WeeklySummary.html"
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./Logs/devmetrics-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId" ]
  },

  "AllowedHosts": "*"
}
