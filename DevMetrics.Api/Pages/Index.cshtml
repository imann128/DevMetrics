@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";

    // Serialize server-side data into JS-safe JSON for chart bootstrapping.
    // JsonSerializerOptions uses camelCase to match the API's serialization.
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var summariesJson    = JsonSerializer.Serialize(Model.DashboardData?.DailySummaries
                               ?? new List<CommitSummaryDto>(), jsonOptions);
    var repositoriesJson = JsonSerializer.Serialize(Model.Repositories
                               ?? new List<RepositoryDto>(), jsonOptions);
}

@section Styles {
<style>
  /* ── Card polish ────────────────────────────────────────────────────── */
  .dm-card          { border: 1px solid var(--bs-border-color); border-radius: .75rem; }
  .dm-card .card-header {
    background: transparent;
    border-bottom: 1px solid var(--bs-border-color);
    font-weight: 600;
    font-size: .875rem;
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  /* ── Stat pill badges ───────────────────────────────────────────────── */
  .stat-pill        { font-size: .8rem; padding: .25em .65em; border-radius: 999px; }

  /* ── Repo table ─────────────────────────────────────────────────────── */
  #repo-table td, #repo-table th { vertical-align: middle; font-size: .875rem; }
  .repo-path        { font-family: var(--bs-font-monospace); font-size: .8rem;
                      max-width: 260px; overflow: hidden; text-overflow: ellipsis;
                      white-space: nowrap; }

  /* ── Scan badge freshness ───────────────────────────────────────────── */
  .stale            { color: var(--bs-warning); }
  .fresh            { color: var(--bs-success); }

  /* ── Connection dot (pulsing when connected) ────────────────────────── */
  .connection-dot   { display: inline-block; width: 8px; height: 8px;
                      border-radius: 50%; background: currentColor; }
  #connection-badge.connected    { background-color: var(--bs-success); }
  #connection-badge.connected .connection-dot { animation: pulse 2s infinite; }
  #connection-badge.reconnecting { background-color: var(--bs-warning); color: #000; }
  #connection-badge.disconnected { background-color: var(--bs-danger); }

  @@keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: .4; }
  }

  /* ── Chart container ────────────────────────────────────────────────── */
  .chart-wrap       { position: relative; height: 320px; }

  /* ── Validation ─────────────────────────────────────────────────────── */
  .validation-summary-errors ul { margin: 0; padding-left: 1.2rem; }
</style>
}

<!-- ── Page header ────────────────────────────────────────────────────────── -->
<div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-2">
  <div>
    <h1 class="h3 mb-0 fw-bold">Developer Productivity</h1>
    <p class="text-body-secondary mb-0 small">
      Last scan:
      <span id="last-scan-time" class="fw-medium">
        @(Model.DashboardData?.LastScanTime.HasValue == true
          ? Model.DashboardData.LastScanTime.Value.AddHours(5).ToString("yyyy-MM-dd HH:mm") + " PKT"
          : "Never")
      </span>
    </p>
  </div>

  <!-- Manual scan trigger -->
  <button id="btn-trigger-scan"
          class="btn btn-primary d-flex align-items-center gap-2"
          title="Trigger an immediate scan">
    <i class="bi bi-arrow-clockwise"></i>
    <span>Scan now</span>
    <span id="scan-spinner"
          class="spinner-border spinner-border-sm d-none"
          role="status" aria-hidden="true"></span>
  </button>
</div>

<!-- ── Top row: stat cards ────────────────────────────────────────────────── -->
<div class="row g-3 mb-4" id="stat-cards">
  <div class="col-6 col-md-3">
    <div class="card dm-card h-100">
      <div class="card-body">
        <div class="text-body-secondary small mb-1">Repositories</div>
        <div class="h3 fw-bold mb-0" id="stat-repos">
          @(Model.Repositories?.Count ?? 0)
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card dm-card h-100">
      <div class="card-body">
        <div class="text-body-secondary small mb-1">Commits (14d)</div>
        <div class="h3 fw-bold mb-0" id="stat-commits">
          @(Model.DashboardData?.DailySummaries.Sum(d => d.TotalCommits) ?? 0)
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card dm-card h-100">
      <div class="card-body">
        <div class="text-body-secondary small mb-1">Lines Added (14d)</div>
        <div class="h3 fw-bold mb-0 text-success" id="stat-added">
          +@(Model.DashboardData?.DailySummaries.Sum(d => d.LinesAdded) ?? 0)
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card dm-card h-100">
      <div class="card-body">
        <div class="text-body-secondary small mb-1">Lines Deleted (14d)</div>
        <div class="h3 fw-bold mb-0 text-danger" id="stat-deleted">
          -@(Model.DashboardData?.DailySummaries.Sum(d => d.LinesDeleted) ?? 0)
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── Chart row ──────────────────────────────────────────────────────────── -->
<div class="card dm-card mb-4">
  <div class="card-header d-flex align-items-center justify-content-between">
    <span><i class="bi bi-bar-chart-line me-2"></i>Commit activity</span>
    <div class="d-flex gap-2 align-items-center">
      <!-- Day-window selector -->
      <select id="chart-days" class="form-select form-select-sm" style="width:auto">
        <option value="7">7 days</option>
        <option value="14" selected>14 days</option>
        <option value="30">30 days</option>
        <option value="90">90 days</option>
      </select>
      <div id="chart-loading"
           class="spinner-border spinner-border-sm text-secondary d-none"
           role="status" aria-hidden="true"></div>
    </div>
  </div>
  <div class="card-body">
    <div class="chart-wrap">
      <canvas id="activity-chart" aria-label="Commit activity over time"></canvas>
    </div>
    <div id="chart-empty"
         class="text-center text-body-secondary py-5 d-none">
      <i class="bi bi-bar-chart fs-1 d-block mb-2"></i>
      No commit data yet. Add a repository and trigger a scan to get started.
    </div>
  </div>
</div>

<!-- ── Bottom row: repositories + add-repo ───────────────────────────────── -->
<div class="row g-4">

  <!-- ── Add repository card ─────────────────────────────────────────── -->
  <div class="col-lg-4">
    <div class="card dm-card h-100">
      <div class="card-header">
        <i class="bi bi-plus-circle me-2"></i>Add Repository
      </div>
      <div class="card-body">

        @* Server-side add (works without JS) *@
        <form method="post" asp-page-handler="AddRepository" id="add-repo-form"
              novalidate>
          @Html.AntiForgeryToken()

          <div class="mb-3">
            <label for="RepoPath" class="form-label fw-medium">
              Absolute path
            </label>
            <div class="input-group">
              <span class="input-group-text">
                <i class="bi bi-folder2-open"></i>
              </span>
              <input type="text"
                     id="RepoPath"
                     name="NewRepositoryPath"
                     class="form-control font-monospace"
                     placeholder="/home/user/projects/my-repo"
                     value="@Model.NewRepositoryPath"
                     autocomplete="off"
                     spellcheck="false"
                     required />
            </div>
            <div class="form-text">
              Must contain a <code>.git</code> directory.
            </div>
          </div>

          @if (!string.IsNullOrEmpty(Model.AddRepoError))
          {
            <div class="alert alert-danger alert-dismissible py-2 small" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-1"></i>
              @Model.AddRepoError
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
          }

          @if (!string.IsNullOrEmpty(Model.AddRepoSuccess))
          {
            <div class="alert alert-success py-2 small" role="alert">
              <i class="bi bi-check-circle-fill me-1"></i>
              @Model.AddRepoSuccess
            </div>
          }

          <button type="submit"
                  id="btn-add-repo"
                  class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2">
            <i class="bi bi-plus-lg"></i>
            <span>Track Repository</span>
            <span id="add-repo-spinner"
                  class="spinner-border spinner-border-sm d-none"
                  role="status" aria-hidden="true"></span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Repositories list card ──────────────────────────────────────── -->
  <div class="col-lg-8">
    <div class="card dm-card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-diagram-3 me-2"></i>Tracked Repositories</span>
        <span id="repo-count-badge"
              class="badge bg-primary rounded-pill">
          @(Model.Repositories?.Count ?? 0)
        </span>
      </div>
      <div class="card-body p-0">

        <!-- Loading state -->
        <div id="repo-loading" class="text-center py-5 d-none">
          <div class="spinner-border text-primary mb-2" role="status"></div>
          <div class="small text-body-secondary">Loading repositories…</div>
        </div>

        <!-- Empty state -->
        <div id="repo-empty"
             class="text-center py-5 @(Model.Repositories?.Count > 0 ? "d-none" : "")">
          <i class="bi bi-git fs-1 text-body-secondary d-block mb-2"></i>
          <p class="text-body-secondary mb-0">No repositories tracked yet.</p>
          <p class="small text-body-secondary">Add one using the form on the left.</p>
        </div>

        <!-- Table -->
        <div id="repo-table-wrap"
             class="@(Model.Repositories?.Count > 0 ? "" : "d-none")">
          <table class="table table-hover mb-0" id="repo-table">
            <thead class="table-light">
              <tr>
                <th scope="col">Name</th>
                <th scope="col" class="d-none d-md-table-cell">Path</th>
                <th scope="col">Last scanned</th>
                <th scope="col" class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody id="repo-tbody">
              @foreach (var repo in (Model.Repositories ?? new List<RepositoryDto>()))
              {
                var isStale = (DateTime.UtcNow - repo.LastScannedUtc).TotalHours > 2;
                <tr data-repo-id="@repo.Id">
                  <td>
                    <span class="fw-medium">@repo.Name</span>
                  </td>
                  <td class="d-none d-md-table-cell">
                    <span class="repo-path text-body-secondary"
                          title="@repo.Path">@repo.Path</span>
                  </td>
                  <td>
                    <span class="@(isStale ? "stale" : "fresh")"
                          title="@repo.LastScannedUtc.ToString("u")">
                      <i class="bi @(isStale ? "bi-clock-history" : "bi-check-circle-fill") me-1"></i>
                      <span class="scan-time"
                            data-utc="@repo.LastScannedUtc.ToString("O")">
                        @(repo.LastScannedUtc == DateTime.UnixEpoch
                            ? "Never"
                            : repo.LastScannedUtc.AddHours(5).ToString("MMM d, HH:mm") + " PKT")
                      </span>
                    </span>
                  </td>
                  <td class="text-end">
                    <button class="btn btn-sm btn-outline-danger btn-delete-repo"
                            data-repo-id="@repo.Id"
                            data-repo-name="@repo.Name"
                            title="Remove @repo.Name">
                      <i class="bi bi-trash3"></i>
                    </button>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div><!-- /.row -->

@section Scripts {
<script>
  // ── Bootstrap the chart from server-rendered data ────────────────────────
  // These variables are written by the Razor template using server-side data,
  // so the chart is fully populated on first paint — no extra round-trip needed.
  window.DM = {
    initialSummaries:    @Html.Raw(summariesJson),
    initialRepositories: @Html.Raw(repositoriesJson),
    apiBase:             '',        // same origin
    hubUrl:              '/dashboardHub',
  };
</script>
<script src="~/js/dashboard.js"></script>
}