@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";

    var jsonOptions      = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var summariesJson    = JsonSerializer.Serialize(Model.DashboardData?.DailySummaries
                               ?? new List<CommitSummaryDto>(), jsonOptions);
    var repositoriesJson = JsonSerializer.Serialize(Model.Repositories
                               ?? new List<RepositoryDto>(), jsonOptions);

    var totalCommits  = Model.DashboardData?.DailySummaries.Sum(d => d.TotalCommits)  ?? 0;
    var totalAdded    = Model.DashboardData?.DailySummaries.Sum(d => d.LinesAdded)    ?? 0;
    var totalDeleted  = Model.DashboardData?.DailySummaries.Sum(d => d.LinesDeleted)  ?? 0;
    var repoCount     = Model.Repositories?.Count ?? 0;
}

<!-- ── Page header ────────────────────────────────────────────────────────── -->
<div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-2">
  <div>
    <h1 class="h3 mb-0 fw-bold">Developer Productivity</h1>
    <p class="text-body-secondary mb-0 small">
      Last scan:
      <span id="last-scan-time" class="fw-medium">
        @(Model.DashboardData?.LastScanTime.HasValue == true
          ? Model.DashboardData.LastScanTime.Value.AddHours(5).ToString("yyyy-MM-dd HH:mm") + " PKT"
          : "Never")
      </span>
    </p>
  </div>

  <button id="btn-trigger-scan"
          class="btn btn-primary d-flex align-items-center gap-2"
          title="Trigger an immediate scan">
    <i class="bi bi-arrow-clockwise"></i>
    <span>Scan now</span>
    <span id="scan-spinner"
          class="spinner-border spinner-border-sm d-none"
          role="status" aria-hidden="true"></span>
  </button>
</div>

<!-- ── Stat cards ─────────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">

  <!-- Commits -->
  <div class="col-6 col-md-4 col-lg-2">
    <div class="card dm-card dm-stat-card h-100" style="--dm-accent:#6366f1">
      <div class="card-body px-3 py-3">
        <div class="stat-label"><i class="bi bi-git me-1"></i>Commits</div>
        <div class="stat-value text-primary" id="stat-commits">@totalCommits</div>
        <div class="dm-trend" id="trend-commits"></div>
        <div class="stat-sublabel">last 14 days</div>
      </div>
    </div>
  </div>

  <!-- Lines added -->
  <div class="col-6 col-md-4 col-lg-2">
    <div class="card dm-card dm-stat-card h-100" style="--dm-accent:#22c55e">
      <div class="card-body px-3 py-3">
        <div class="stat-label"><i class="bi bi-plus-lg me-1"></i>Lines Added</div>
        <div class="stat-value text-success" id="stat-added">+@totalAdded</div>
        <div class="dm-trend" id="trend-added"></div>
        <div class="stat-sublabel">last 14 days</div>
      </div>
    </div>
  </div>

  <!-- Lines deleted -->
  <div class="col-6 col-md-4 col-lg-2">
    <div class="card dm-card dm-stat-card h-100" style="--dm-accent:#ef4444">
      <div class="card-body px-3 py-3">
        <div class="stat-label"><i class="bi bi-dash-lg me-1"></i>Lines Deleted</div>
        <div class="stat-value text-danger" id="stat-deleted">-@totalDeleted</div>
        <div class="dm-trend" id="trend-deleted"></div>
        <div class="stat-sublabel">last 14 days</div>
      </div>
    </div>
  </div>

  <!-- Active days -->
  <div class="col-6 col-md-4 col-lg-2">
    <div class="card dm-card dm-stat-card h-100" style="--dm-accent:#8b5cf6">
      <div class="card-body px-3 py-3">
        <div class="stat-label"><i class="bi bi-calendar-check me-1"></i>Active Days</div>
        <div class="stat-value" id="stat-active">—</div>
        <div class="stat-sublabel">with commits</div>
      </div>
    </div>
  </div>

  <!-- Current streak -->
  <div class="col-6 col-md-4 col-lg-2">
    <div class="card dm-card dm-stat-card h-100" style="--dm-accent:#f59e0b">
      <div class="card-body px-3 py-3">
        <div class="stat-label"><i class="bi bi-fire me-1"></i>Streak</div>
        <div class="stat-value" id="stat-streak">—</div>
        <div class="stat-sublabel">consecutive days</div>
      </div>
    </div>
  </div>

  <!-- Peak day -->
  <div class="col-6 col-md-4 col-lg-2">
    <div class="card dm-card dm-stat-card h-100" style="--dm-accent:#06b6d4">
      <div class="card-body px-3 py-3">
        <div class="stat-label"><i class="bi bi-trophy me-1"></i>Peak Day</div>
        <div class="stat-value" id="stat-peak">—</div>
        <div class="stat-sublabel" id="stat-peak-date">commits in one day</div>
      </div>
    </div>
  </div>

</div><!-- /.row stat cards -->

<!-- ── Chart ──────────────────────────────────────────────────────────────── -->
<div class="card dm-card mb-4">
  <div class="card-header d-flex align-items-center justify-content-between">
    <span><i class="bi bi-bar-chart-line me-2"></i>Commit activity</span>
    <div class="d-flex gap-2 align-items-center">
      <select id="chart-days" class="form-select form-select-sm" style="width:auto">
        <option value="7">7 days</option>
        <option value="14" selected>14 days</option>
        <option value="30">30 days</option>
        <option value="90">90 days</option>
      </select>
      <div id="chart-loading"
           class="spinner-border spinner-border-sm text-secondary d-none"
           role="status" aria-hidden="true"></div>
    </div>
  </div>
  <div class="card-body">
    <div class="chart-wrap">
      <canvas id="activity-chart" aria-label="Commit activity over time"></canvas>
    </div>
    <div id="chart-empty"
         class="text-center text-body-secondary py-5 d-none">
      <i class="bi bi-bar-chart fs-1 d-block mb-2"></i>
      No commit data yet. Add a repository and trigger a scan to get started.
    </div>
  </div>
  <!-- Highlights strip -->
  <div class="highlight-strip" id="highlight-strip">
    <div class="highlight-item">
      <span class="hi-icon">🔥</span>
      <span class="hi-value" id="hl-streak">—</span>
      <span class="hi-label">day streak</span>
    </div>
    <div class="highlight-item">
      <span class="hi-icon">🏆</span>
      <span class="hi-value" id="hl-peak">—</span>
      <span class="hi-label">best day (<span id="hl-peak-date">—</span>)</span>
    </div>
    <div class="highlight-item">
      <span class="hi-icon">📅</span>
      <span class="hi-value" id="hl-active">—</span>
      <span class="hi-label">active days in window</span>
    </div>
    <div class="highlight-item">
      <span class="hi-icon">📦</span>
      <span class="hi-value" id="stat-repos">@repoCount</span>
      <span class="hi-label">repositories tracked</span>
    </div>
  </div>
</div>

<!-- ── Bottom row: repositories + add-repo ───────────────────────────────── -->
<div class="row g-4">

  <!-- Add repository -->
  <div class="col-lg-4">
    <div class="card dm-card h-100">
      <div class="card-header">
        <i class="bi bi-plus-circle me-2"></i>Add Repository
      </div>
      <div class="card-body">
        <form method="post" asp-page-handler="AddRepository" id="add-repo-form" novalidate>
          @Html.AntiForgeryToken()
          <div class="mb-3">
            <label for="RepoPath" class="form-label fw-medium">Path</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-folder2-open"></i></span>
              <input type="text"
                     id="RepoPath"
                     name="NewRepositoryPath"
                     class="form-control font-monospace"
                     placeholder="/repos/my-project"
                     value="@Model.NewRepositoryPath"
                     autocomplete="off"
                     spellcheck="false"
                     required />
            </div>
            <div class="form-text">
              Must be a valid Git repository path.
              In Docker, use the container path (e.g. <code>/repos/my-project</code>).
            </div>
          </div>

          @if (!string.IsNullOrEmpty(Model.AddRepoError))
          {
            <div class="alert alert-danger alert-dismissible py-2 small" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-1"></i>
              @Model.AddRepoError
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
          }

          @if (!string.IsNullOrEmpty(Model.AddRepoSuccess))
          {
            <div class="alert alert-success py-2 small" role="alert">
              <i class="bi bi-check-circle-fill me-1"></i>
              @Model.AddRepoSuccess
            </div>
          }

          <button type="submit"
                  id="btn-add-repo"
                  class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2">
            <i class="bi bi-plus-lg"></i>
            <span>Track Repository</span>
            <span id="add-repo-spinner"
                  class="spinner-border spinner-border-sm d-none"
                  role="status" aria-hidden="true"></span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Repositories list -->
  <div class="col-lg-8">
    <div class="card dm-card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-diagram-3 me-2"></i>Tracked Repositories</span>
        <span id="repo-count-badge" class="badge bg-primary rounded-pill">
          @repoCount
        </span>
      </div>
      <div class="card-body p-0">

        <div id="repo-loading" class="text-center py-5 d-none">
          <div class="spinner-border text-primary mb-2" role="status"></div>
          <div class="small text-body-secondary">Loading repositories…</div>
        </div>

        <div id="repo-empty"
             class="text-center py-5 @(Model.Repositories?.Count > 0 ? "d-none" : "")">
          <i class="bi bi-git fs-1 text-body-secondary d-block mb-2"></i>
          <p class="text-body-secondary mb-0">No repositories tracked yet.</p>
          <p class="small text-body-secondary">Add one using the form on the left.</p>
        </div>

        <div id="repo-table-wrap"
             class="@(Model.Repositories?.Count > 0 ? "" : "d-none")">
          <table class="table table-hover mb-0" id="repo-table">
            <thead class="table-light">
              <tr>
                <th scope="col">Name</th>
                <th scope="col" class="d-none d-md-table-cell">Path</th>
                <th scope="col">Last scanned</th>
                <th scope="col" class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody id="repo-tbody">
              @foreach (var repo in (Model.Repositories ?? new List<RepositoryDto>()))
              {
                var isStale = (DateTime.UtcNow - repo.LastScannedUtc).TotalHours > 2;
                <tr data-repo-id="@repo.Id">
                  <td><span class="fw-medium">@repo.Name</span></td>
                  <td class="d-none d-md-table-cell">
                    <span class="repo-path text-body-secondary" title="@repo.Path">@repo.Path</span>
                  </td>
                  <td>
                    <span class="@(isStale ? "stale" : "fresh")">
                      <i class="bi @(isStale ? "bi-clock-history" : "bi-check-circle-fill") me-1"></i>
                      @(repo.LastScannedUtc == DateTime.UnixEpoch
                          ? "Never"
                          : repo.LastScannedUtc.AddHours(5).ToString("MMM d, HH:mm") + " PKT")
                    </span>
                  </td>
                  <td class="text-end">
                    <button class="btn btn-sm btn-outline-danger btn-delete-repo"
                            data-repo-id="@repo.Id"
                            data-repo-name="@repo.Name"
                            title="Remove @repo.Name">
                      <i class="bi bi-trash3"></i>
                    </button>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div><!-- /.row -->

@section Scripts {
<script>
  window.DM = {
    initialSummaries:    @Html.Raw(summariesJson),
    initialRepositories: @Html.Raw(repositoriesJson),
    apiBase:             '',
    hubUrl:              '/dashboardHub',
  };
</script>
<script src="~/js/dashboard.js"></script>
}
